+++ b/src/main/java/io/papermc/paper/util/SizeLimitedSet.java
@@ -0,0 +1,38 @@
+package io.papermc.paper.util;
+
+import org.jspecify.annotations.NullMarked;
+import java.util.Collection;
+import java.util.HashSet;
+
+@NullMarked
+public class SizeLimitedSet extends HashSet<String> {
+    private final int maxTags;
+
+    public SizeLimitedSet(int maxTags) {
+        this.maxTags = maxTags;
+    }
+
+    @Override
+    public boolean add(String tag) {
+        // Enforce the max tag limit
+        if (this.size() >= maxTags) {
+            return false;
+        }
+        return super.add(tag);
+    }
+
+    @Override
+    public boolean addAll(Collection<? extends String> tags) {
+        boolean edited = false;
+
+        for (String tag : tags) {
+            if (this.size() >= maxTags) {
+                break;
+            }
+
+            boolean added = this.add(tag);
+            edited = added || edited;
+        }
+        return edited;
+    }
+}
