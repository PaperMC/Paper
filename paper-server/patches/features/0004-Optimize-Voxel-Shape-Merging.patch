-                return new DiscreteCubeMerger(firstSize, secondSize);
+                return new net.minecraft.world.phys.shapes.DiscreteCubeMerger(firstSize, secondSize);
             }
         }
 
-        if (first.getDouble(firstSize) < second.getDouble(0) - 1.0E-7) {
-            return new NonOverlappingMerger(first, second, false);
+        // Paper start - Identical happens more often than Disjoint
+        if (firstSize == secondSize && java.util.Objects.equals(first, second)) {
+            if (first instanceof net.minecraft.world.phys.shapes.IdenticalMerger) {
+                return (net.minecraft.world.phys.shapes.IndexMerger) first;
+            } else if (second instanceof net.minecraft.world.phys.shapes.IdenticalMerger) {
+                return (net.minecraft.world.phys.shapes.IndexMerger) second;
+            }
+            return new net.minecraft.world.phys.shapes.IdenticalMerger(first);
+        } else if (first.getDouble(firstSize) < second.getDouble(0) - 1.0E-7) {
+            // Paper end - Identical happens more often than Disjoint
+            return new net.minecraft.world.phys.shapes.NonOverlappingMerger(first, second, false);
         } else if (second.getDouble(secondSize) < first.getDouble(0) - 1.0E-7) {
-            return new NonOverlappingMerger(second, first, true);
+            return new net.minecraft.world.phys.shapes.NonOverlappingMerger(second, first, true);
         } else {
-            return (IndexMerger)(firstSize == secondSize && Objects.equals(first, second)
-                ? new IdenticalMerger(first)
-                : new IndirectMerger(first, second, firstOnlyMatters, secondOnlyMatters));
+            return new net.minecraft.world.phys.shapes.IndirectMerger(first, second, firstOnlyMatters, secondOnlyMatters); // Paper - Identical happens more often than Disjoint
         }
     }
 
