+    private static net.minecraft.world.phys.shapes.IndexMerger createIndexMerger( // Paper - private
+        final int cost, final it.unimi.dsi.fastutil.doubles.DoubleList first, final it.unimi.dsi.fastutil.doubles.DoubleList second, final boolean firstOnlyMatters, final boolean secondOnlyMatters
+    ) { // Paper - private
+        // Paper start - fast track the most common scenario
+        // doublelist is usually a DoubleArrayList with Infinite head/tails that falls to the final else clause
+        // This is actually the most common path, so jump to it straight away
+        if (first.getDouble(0) == Double.NEGATIVE_INFINITY && first.getDouble(first.size() - 1) == Double.POSITIVE_INFINITY) {
+            return new net.minecraft.world.phys.shapes.IndirectMerger(first, second, firstOnlyMatters, secondOnlyMatters);
+        }
+        // Split out rest to hopefully inline the above
+        return lessCommonMerge(cost, first, second, firstOnlyMatters, secondOnlyMatters);
+    }
+
+    private static net.minecraft.world.phys.shapes.IndexMerger lessCommonMerge(
+        final int cost, final it.unimi.dsi.fastutil.doubles.DoubleList first, final it.unimi.dsi.fastutil.doubles.DoubleList second, final boolean firstOnlyMatters, final boolean secondOnlyMatters) {
+        // Paper end - fast track the most common scenario
         int firstSize = first.size() - 1;
         int secondSize = second.size() - 1;
