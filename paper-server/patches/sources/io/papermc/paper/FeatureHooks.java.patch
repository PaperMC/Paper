+            net.minecraft.world.phys.shapes.Shapes.create(entity.getBoundingBox().inflate(net.minecraft.util.Util.COLLISION_EPSILON)), net.minecraft.world.phys.shapes.BooleanOp.AND
+        ) && border.isInsideCloseToBorder(entity, entity.getBoundingBox());
