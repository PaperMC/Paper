+                target = ((org.bukkit.craftbukkit.entity.CraftLivingEntity) event.getTarget()).getHandle();
+            } else {
+                target = null;
+            }
+        }
         this.target = this.asValidTarget(target);
+        return true;
+        // CraftBukkit end
