From 5e6b33d90f104b017d79526da9538bfd0934fc41 Mon Sep 17 00:00:00 2001
From: File <noreply+automated@papermc.io>
Date: Sun, 20 Apr 1997 15:37:42 +0200
Subject: [PATCH] paper File Patches


diff --git a/net/minecraft/world/entity/animal/frog/Tadpole.java b/net/minecraft/world/entity/animal/frog/Tadpole.java
index 43b4e918626770cf9fb254b1d22779beafba3480..3d4bfeae2fddb9ace26e7dea8870704d8309862b 100644
--- a/net/minecraft/world/entity/animal/frog/Tadpole.java
+++ b/net/minecraft/world/entity/animal/frog/Tadpole.java
@@ -127,7 +127,7 @@ public class Tadpole extends AbstractFish {
         entityData.define(AGE_LOCKED, false);
     }
 
-    protected void setAgeLocked(final boolean locked) {
+    public void setAgeLocked(final boolean locked) { // Paper - public
         this.entityData.set(AGE_LOCKED, locked);
     }
 
@@ -157,6 +157,11 @@ public class Tadpole extends AbstractFish {
             this.feed(player, itemStack);
             return InteractionResult.SUCCESS;
         } else if (AgeableMob.canUseGoldenDandelion(itemStack, true, this.ageLockParticleTimer, this)) {
+            // Paper start - call PlayerToggleEntityAgeLockEvent
+            if (!org.bukkit.craftbukkit.event.CraftEventFactory.callPlayerToggleEntityAgeLockEvent(player, this, itemStack, hand, !this.isAgeLocked(), AGE_LOCKED)) {
+                return InteractionResult.SUCCESS;
+            }
+            // Paper end - call PlayerToggleEntityAgeLockEvent
             AgeableMob.setAgeLocked(this, this::isAgeLocked, player, itemStack, mob -> this.setAgeLockedData());
             return InteractionResult.SUCCESS;
         } else {
@@ -236,12 +241,17 @@ public class Tadpole extends AbstractFish {
 
     private void ageUp() {
         if (this.level() instanceof ServerLevel serverLevel) {
-            this.convertTo(EntityType.FROG, ConversionParams.single(this, false, false), frog -> {
+            Frog converted = this.convertTo(EntityType.FROG, ConversionParams.single(this, false, false), frog -> { // CraftBukkit
                 frog.finalizeSpawn(serverLevel, serverLevel.getCurrentDifficultyAt(frog.blockPosition()), EntitySpawnReason.CONVERSION, null);
                 frog.setPersistenceRequired();
                 frog.fudgePositionAfterSizeChange(this.getDimensions(this.getPose()));
                 this.playSound(SoundEvents.TADPOLE_GROW_UP, 0.15F, 1.0F);
-            });
+            // CraftBukkit start
+            }, org.bukkit.event.entity.EntityTransformEvent.TransformReason.METAMORPHOSIS, org.bukkit.event.entity.CreatureSpawnEvent.SpawnReason.METAMORPHOSIS);
+            if (converted == null) {
+                this.setAge(0); // Sets the age to 0 for avoid a loop if the event is canceled
+            }
+            // CraftBukkit end
         }
     }
 
