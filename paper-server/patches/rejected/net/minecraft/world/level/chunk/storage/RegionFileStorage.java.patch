+        if (region == null) {
+            return;
+        }
+        // CraftBukkit end
 
         try (DataInputStream regionChunkInputStream = region.getChunkDataInputStream(pos)) {
             if (regionChunkInputStream != null) {
@@ -74,7 +86,7 @@ public final class RegionFileStorage implements AutoCloseable {
 
