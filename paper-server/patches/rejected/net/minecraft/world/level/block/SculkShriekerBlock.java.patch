         if (level instanceof ServerLevel serverLevel) {
             ServerPlayer player = SculkShriekerBlockEntity.tryGetPlayer(entity);
             if (player != null) {
+                if (org.bukkit.craftbukkit.event.CraftEventFactory.callPlayerInteractEvent(player, org.bukkit.event.block.Action.PHYSICAL, pos, null, null, null).isCancelled()) return; // CraftBukkit
