         super.spawnAfterBreak(state, level, pos, tool, dropExperience);
+        // CraftBukkit start - Delegate to getExpDrop
+    }
+
+    @Override
+    public int getExpDrop(final BlockState state, final ServerLevel level, final BlockPos pos, final ItemStack tool, final boolean dropExperience) {
         if (dropExperience) {
-            this.tryDropExperience(level, pos, tool, ConstantInt.of(5));
+            return this.tryDropExperience(level, pos, tool, ConstantInt.of(5));
         }
+        return 0;
