+        level.setBlock(pos, newState, Block.UPDATE_ALL);
         level.gameEvent(player, GameEvent.BLOCK_CHANGE, pos);
+        return InteractionResult.SUCCESS;
+        // Paper end - call EntityChangeBlockEvent
     }
 
